{
  "name": "pencil-agent",
  "version": "1.0.0",
  "description": "AI Agent Desktop - 基于 pi-mono Agent 引擎的桌面端 AI Agent 平台",
  "main": "./out/main/index.mjs",
  "author": "Pencil Agent Team",
  "homepage": "https://github.com/pencil-agent/pencil-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/pencil-agent/pencil-agent.git"
  },
  "keywords": [
    "electron",
    "react",
    "ai-agent",
    "desktop"
  ],
  "scripts": {
    "lint": "oxlint --fix src",
    "fmt": "oxfmt src",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "tsx scripts/generate-cpu-features-gypi.ts && tsx scripts/ensure-electron.ts && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^12.10.0",
    "chromadb": "^3.4.3",
    "dockerode": "^5.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.40.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.0",
    "react-i18next": "^17.0.8",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.8"
  }
}
